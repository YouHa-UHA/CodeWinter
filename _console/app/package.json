{
  "name": "codewinter-operator-console",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "cd .. && npm exec --prefix app -- tauri dev --config src-tauri/tauri.conf.json",
    "tauri:build": "cd .. && npm exec --prefix app -- tauri build --config src-tauri/tauri.conf.json",
    "tauri:build:nsis": "cd .. && npm exec --prefix app -- tauri build --config src-tauri/tauri.conf.json --bundles nsis",
    "tauri:info": "cd .. && npm exec --prefix app -- tauri info",
    "release:windows": "cd .. && powershell -NoProfile -ExecutionPolicy Bypass -File scripts\\release-windows.ps1"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@tauri-apps/api": "^2.8.0",
    "antd": "^6.3.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.9.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CodeWinter Operator Console",
  "version": "0.1.1",
  "identifier": "com.codewinter.operator-console",
  "build": {
    "beforeDevCommand": "npm --prefix ../app run dev",
    "beforeBuildCommand": "npm --prefix ../app run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../app/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CodeWinter Operator Console",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
